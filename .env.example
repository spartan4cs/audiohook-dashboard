# ────────────────────────────────────────────────────────────
#  .env.example — copy to .env for local development
#  NEVER commit .env to git
#
#  Authentication: Vertex AI uses Application Default Credentials (ADC).
#  No API key needed. Authenticate once locally with:
#    gcloud auth application-default login
# ────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# ── Auth ──────────────────────────────────────────────────────
# Use "dev-key" for local testing (auth is bypassed)
AUDIOHOOK_API_KEY=dev-key

# ── Vertex AI ─────────────────────────────────────────────────
# These three vars are read directly by the @google/genai SDK.
# On Cloud Run they are set automatically via the service definition.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=gemini-test2-491816
GOOGLE_CLOUD_LOCATION=us-central1

# Model names (same identifiers work on both Vertex AI and Dev API)
GEMINI_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_SUMMARY_MODEL=gemini-2.5-pro

# ── CRM (set adapter: mock | salesforce | servicenow | hubspot)
CRM_ADAPTER=mock

# Salesforce (only needed when CRM_ADAPTER=salesforce)
SF_INSTANCE_URL=https://myorg.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# ServiceNow (only needed when CRM_ADAPTER=servicenow)
SNOW_INSTANCE_URL=https://myorg.service-now.com
SNOW_USER=
SNOW_PASSWORD=

# HubSpot (only needed when CRM_ADAPTER=hubspot)
HUBSPOT_API_KEY=
