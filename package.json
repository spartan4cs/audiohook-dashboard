{
  "name": "genesys-gemini-agent-assist",
  "version": "2.0.0",
  "description": "Real-time Agent Assist: Genesys AudioHook + Gemini Live → Live Transcript + AI Suggestions + CRM Auto-fill",
  "main": "server.js",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "start"  : "node server.js",
    "dev"    : "nodemon server.js",
    "lint"   : "node --check server.js src/**/*.js",
    "docker:build": "docker build -t audiohook-server .",
    "docker:run"  : "docker run --rm -p 8080:8080 --env-file .env audiohook-server"
  },
  "dependencies": {
    "@google/genai": "^0.7.0",
    "dotenv"       : "^16.4.0",
    "ws"           : "^8.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
